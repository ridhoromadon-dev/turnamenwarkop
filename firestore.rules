rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', 'USER') == role;
    }

    function isSuperAdmin() {
      return hasRole("SUPER_ADMIN");
    }

    // Role hierarchy / Permission helper
    function hasPermission(permission) {
      let role = getUserData().get('role', 'USER');
      return role == "SUPER_ADMIN" || (exists(/databases/$(database)/documents/role_configs/$(role)) && get(/databases/$(database)/documents/role_configs/$(role)).data.get(permission, false) == true);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getUserData().get('isAdmin', false) == true || getUserData().get('role', 'USER') in ["SUPER_ADMIN", "MANAGER", "STAFF"]);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 64 &&
             data.phone is string && data.phone.size() <= 32 &&
             data.team_name is string && data.team_name.size() <= 64 &&
             data.registration_date is string &&
             (data.get('total_wins', 0) is int) &&
             (data.get('role', 'USER') is string) &&
             (data.get('isAdmin', false) is bool);
    }

    function isValidTestimonial(data) {
      return data.user_id is string && data.user_id == request.auth.uid &&
             data.username is string &&
             data.content is string && data.content.size() <= 1000 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.created_at is string;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.completed is bool &&
             data.created_at is string;
    }

    function isValidNotification(data) {
      return data.title is string && data.message is string &&
             data.type in ["info", "success", "warning"] &&
             data.read is bool &&
             data.created_at is string;
    }

    function isValidRoleConfig(data) {
      return data.canEditTheme is bool &&
             data.canManageTasks is bool &&
             data.canManageNotifications is bool &&
             data.canExportData is bool &&
             data.canEditWins is bool &&
             data.canManageUsers is bool &&
             data.id is string;
    }

    // --- RULES ---

    // Rules for role configurations
    match /role_configs/{roleId} {
      allow read: if true;
      allow write: if isSuperAdmin() && isValidRoleConfig(incoming());
    }

    // Rules for users
    match /users/{userId} {
      allow read: if true; // Allow landing page stats, check status, and leaderboard
      
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming()) &&
                    incoming().get('role', 'USER') == 'USER' && incoming().get('isAdmin', false) == false;
      
      allow update: if (isOwner(userId) && (incoming().diff(existing()).affectedKeys().hasOnly(['username', 'phone', 'team_name', 'avatar_url', 'avatarUrl', 'teamName']))) || 
                    (isSuperAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'total_wins', 'isAdmin', 'totalWins'])) ||
                    (hasPermission('canEditWins') && incoming().diff(existing()).affectedKeys().hasOnly(['total_wins', 'totalWins']));
      
      allow delete: if isSuperAdmin();
    }

    // Rules for testimonials
    match /testimonials/{testId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if hasPermission('canManageNotifications') || isOwner(existing().user_id);
    }

    // Rules for settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasPermission('canEditTheme') || !exists(/databases/$(database)/documents/settings/current);
    }

    // Rules for custom themes
    match /themes/{themeId} {
      allow read: if true;
      allow write: if hasPermission('canEditTheme');
    }

    // Rules for tasks
    match /tasks/{taskId} {
      allow read: if isAdmin();
      allow create: if hasPermission('canManageTasks') && isValidTask(incoming());
      allow update: if hasPermission('canManageTasks') && isValidTask(incoming());
      allow delete: if hasPermission('canManageTasks');
    }

    // Rules for notifications
    match /notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if (hasPermission('canManageNotifications') && (incoming().diff(existing()).affectedKeys().hasOnly(['read']) || isValidNotification(incoming())));
      allow delete: if hasPermission('canManageNotifications');
    }
  }
}
